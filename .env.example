# WMSU HR Connect - Environment Configuration Template
# Copy this file to backend/.env and fill in your values
# DO NOT COMMIT backend/.env to version control

# ============================================
# Server Configuration
# ============================================
PORT=4000
NODE_ENV=development

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# Format: postgres://username:password@host:port/database
# Example: postgres://postgres:password123@localhost:5432/wmsu_hr_connect
DATABASE_URL=postgres://postgres:password@localhost:5432/wmsu_hr_connect

# ============================================
# Authentication Configuration (REQUIRED)
# ============================================
# JWT secret key - must be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your_secure_jwt_secret_key_min_32_chars

# JWT token expiration time
# Examples: 7d, 24h, 30d
TOKEN_EXPIRES_IN=7d

# ============================================
# Email Configuration (Optional)
# ============================================
# For sending email notifications
# Leave blank to disable email features

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# File Upload Configuration (Optional)
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ============================================
# Frontend Configuration (for CORS)
# ============================================
FRONTEND_URL=http://localhost:5173
